# =========================================================
# KIVU ADVISORY BACKEND ENVIRONMENT EXAMPLE
# =========================================================

# ---------------------------------------------------------
# Application
# ---------------------------------------------------------
APP_NAME=Kivu Advisory Backend
APP_ENV=development
APP_TIMEZONE=Africa/Kigali

# ---------------------------------------------------------
# Server
# ---------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
API_BASE_PATH=/api/v1

BACKEND_PUBLIC_URL=http://localhost:8080
FRONTEND_PUBLIC_URL=http://localhost:3000

# ---------------------------------------------------------
# CORS
# ---------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin
CORS_ALLOW_CREDENTIALS=true

# ---------------------------------------------------------
# Database
# Replace with your real Neon PostgreSQL URL in backend/.env
# ---------------------------------------------------------
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30
DB_CONN_MAX_IDLE_TIME_MINUTES=10
MIGRATIONS_PATH=file://db/migrations

# ---------------------------------------------------------
# JWT
# Must be at least 32 characters in production.
# ---------------------------------------------------------
JWT_SECRET=replace-with-a-long-development-secret-at-least-32-chars
JWT_ISSUER=kivu-advisory
JWT_AUDIENCE=kivu-advisory-users
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=7

# ---------------------------------------------------------
# Password Security
# Backend rejects weak passwords.
# ---------------------------------------------------------
PASSWORD_MIN_LENGTH=10
BCRYPT_COST=12

# ---------------------------------------------------------
# Storage
#
# Development:
# STORAGE_DRIVER=local
#
# Production:
# STORAGE_DRIVER=r2
# ---------------------------------------------------------
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=storage/private/documents

# ---------------------------------------------------------
# Cloudflare R2
#
# Required only when STORAGE_DRIVER=r2.
# Keep the R2 bucket private.
# ---------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_REGION=auto
R2_PUBLIC_BASE_URL=

# ---------------------------------------------------------
# Uploads
# ---------------------------------------------------------
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,xls,xlsx,png,jpg,jpeg,webp,txt,csv,zip
ALLOWED_UPLOAD_MIME_TYPES=

# ---------------------------------------------------------
# Email
# Optional for now
# ---------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Kivu Advisory
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# ---------------------------------------------------------
# Notifications
# ---------------------------------------------------------
SEND_EMAIL_NOTIFICATIONS=false
NOTIFY_ADMIN_ON_NEW_REQUEST=true
NOTIFY_ADMIN_ON_DOCUMENT_UPLOAD=true
NOTIFY_CLIENT_ON_STATUS_CHANGE=true

# ---------------------------------------------------------
# Bootstrap Admin
#
# ADMIN_PASSWORD must be strong.
# Example: KivuAdmin2026!
# ---------------------------------------------------------
ADMIN_FULL_NAME=System Administrator
ADMIN_EMAIL=admin@kivuadvisory.com
ADMIN_PASSWORD=KivuAdmin2026!
ADMIN_PHONE=+250788000000

# ---------------------------------------------------------
# Logging
# ---------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=text