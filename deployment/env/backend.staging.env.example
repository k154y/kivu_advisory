APP_ENV=staging
APP_NAME=Kivu Advisory Backend
APP_TIMEZONE=Africa/Kigali

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
API_BASE_PATH=/api/v1
BACKEND_PUBLIC_URL=https://api-staging.kivuadisory.com
FRONTEND_PUBLIC_URL=https://staging.kivuadisory.com

CORS_ALLOWED_ORIGINS=https://staging.kivuadisory.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin
CORS_ALLOW_CREDENTIALS=true

DATABASE_URL=PASTE_NEON_STAGING_DATABASE_URL
MIGRATIONS_PATH=file://db/migrations

JWT_SECRET=PASTE_STAGING_JWT_SECRET_32_PLUS_CHARACTERS
JWT_ISSUER=kivu-advisory
JWT_AUDIENCE=kivu-advisory-users
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=7

PASSWORD_MIN_LENGTH=10
BCRYPT_COST=12

ADMIN_FULL_NAME=System Administrator
ADMIN_EMAIL=admin@kivuadisory.com
ADMIN_PHONE=+250700000000
ADMIN_PASSWORD=PASTE_STRONG_STAGING_ADMIN_PASSWORD

STORAGE_DRIVER=r2
R2_ACCOUNT_ID=PASTE_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=PASTE_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=PASTE_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=kivu-advisory-staging
R2_ENDPOINT=https://PASTE_ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
R2_PUBLIC_BASE_URL=

MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,xls,xlsx,png,jpg,jpeg

CREDENTIAL_ENCRYPTION_KEY=PASTE_STAGING_CREDENTIAL_ENCRYPTION_KEY_32_PLUS

SEND_EMAIL_NOTIFICATIONS=true
NOTIFY_ADMIN_ON_NEW_REQUEST=true
NOTIFY_ADMIN_ON_DOCUMENT_UPLOAD=true
NOTIFY_CLIENT_ON_STATUS_CHANGE=true

LOG_LEVEL=debug
LOG_FORMAT=json

EMAIL_PROVIDER=resend
SMS_PROVIDER=log

RESEND_API_KEY=PASTE_RESEND_STAGING_API_KEY
RESEND_FROM_EMAIL=no-reply@kivuadisory.com
RESEND_FROM_NAME=Kivu Advisory Staging

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SENDER=KIVUADV