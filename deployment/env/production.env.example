# =========================================================
# KIVU ADVISORY PRODUCTION ENVIRONMENT EXAMPLE
# =========================================================

# ---------------------------------------------------------
# Application
# ---------------------------------------------------------
APP_NAME=Kivu Advisory Backend
APP_ENV=production
APP_TIMEZONE=Africa/Kigali

# ---------------------------------------------------------
# Server
# In Docker/Caddy production, backend usually listens internally.
# ---------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
API_BASE_PATH=/api/v1

BACKEND_PUBLIC_URL=https://api.kivuadvisory.com
FRONTEND_PUBLIC_URL=https://kivuadvisory.com

# ---------------------------------------------------------
# CORS
# Only allow your real frontend domain in production.
# Add admin domain if separate.
# ---------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://kivuadvisory.com,https://www.kivuadvisory.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin
CORS_ALLOW_CREDENTIALS=true

# ---------------------------------------------------------
# Database - Neon PostgreSQL
# Use the real Neon pooled or direct connection string.
# Keep sslmode=require.
# ---------------------------------------------------------
DATABASE_URL=postgresql://username:password@ep-example.neon.tech/kivu_advisory?sslmode=require

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30
DB_CONN_MAX_IDLE_TIME_MINUTES=10
MIGRATIONS_PATH=file://db/migrations

# ---------------------------------------------------------
# JWT
# Use a strong random secret with at least 32 characters.
# Recommended: 64+ random characters.
# ---------------------------------------------------------
JWT_SECRET=replace-with-real-production-secret-minimum-32-characters
JWT_ISSUER=kivu-advisory
JWT_AUDIENCE=kivu-advisory-users
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=7

# ---------------------------------------------------------
# Password Security
# Backend rejects weak passwords.
# ---------------------------------------------------------
PASSWORD_MIN_LENGTH=10
BCRYPT_COST=12

# ---------------------------------------------------------
# Storage
# Production must use Cloudflare R2.
# ---------------------------------------------------------
STORAGE_DRIVER=r2
LOCAL_UPLOAD_DIR=storage/private/documents

# ---------------------------------------------------------
# Cloudflare R2
# Bucket must remain private.
# The backend controls all downloads after permission checks.
# ---------------------------------------------------------
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=kivu-advisory-documents
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_REGION=auto
R2_PUBLIC_BASE_URL=

# ---------------------------------------------------------
# Uploads
# ---------------------------------------------------------
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,xls,xlsx,png,jpg,jpeg,webp,txt,csv,zip
ALLOWED_UPLOAD_MIME_TYPES=

# ---------------------------------------------------------
# Email
# Fill these when email notifications are ready.
# ---------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=notifications@example.com
SMTP_PASSWORD=replace-with-real-smtp-password
SMTP_FROM_NAME=Kivu Advisory
SMTP_FROM_EMAIL=notifications@kivuadvisory.com
SMTP_USE_TLS=true

# ---------------------------------------------------------
# Notifications
# ---------------------------------------------------------
SEND_EMAIL_NOTIFICATIONS=false
NOTIFY_ADMIN_ON_NEW_REQUEST=true
NOTIFY_ADMIN_ON_DOCUMENT_UPLOAD=true
NOTIFY_CLIENT_ON_STATUS_CHANGE=true

# ---------------------------------------------------------
# Bootstrap Admin
# Use a strong password.
# After first bootstrap, admin will already exist.
# ---------------------------------------------------------
ADMIN_FULL_NAME=System Administrator
ADMIN_EMAIL=admin@kivuadvisory.com
ADMIN_PASSWORD=ReplaceWithStrongAdmin2026!
ADMIN_PHONE=+250788000000

# ---------------------------------------------------------
# Logging
# ---------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=text