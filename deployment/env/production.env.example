# =========================================================
# KIVU ADVISORY - PRODUCTION ENVIRONMENT EXAMPLE
# =========================================================
# Copy this file to deployment/env/production.env on the server.
# Never commit the real production.env file.
#
# Production architecture:
# - Frontend container: Next.js
# - Backend container: Go API
# - Reverse proxy container: Caddy or Nginx
# - Database: Neon PostgreSQL
# - File storage: Cloudflare R2
# =========================================================

# =========================================================
# Application
# =========================================================
APP_NAME=Kivu Advisory
APP_ENV=production
APP_TIMEZONE=Africa/Kigali

# =========================================================
# Domain
# =========================================================
APP_DOMAIN=yourdomain.com
FRONTEND_PUBLIC_URL=https://yourdomain.com
BACKEND_PUBLIC_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1

# =========================================================
# Reverse proxy
# =========================================================
REVERSE_PROXY_HTTP_PORT=80
REVERSE_PROXY_HTTPS_PORT=443
CADDY_EMAIL=admin@yourdomain.com

# =========================================================
# Internal container networking
# =========================================================
FRONTEND_INTERNAL_URL=http://frontend:3000
BACKEND_INTERNAL_URL=http://backend:8080

FRONTEND_PORT=3000
BACKEND_PORT=8080

# =========================================================
# Backend server
# =========================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
API_VERSION=v1
API_BASE_PATH=/api/v1

# =========================================================
# CORS
# =========================================================
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin
CORS_ALLOW_CREDENTIALS=true

# =========================================================
# Neon PostgreSQL
# =========================================================
# Get this from Neon dashboard.
# Production must use sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30
DB_CONN_MAX_IDLE_TIME_MINUTES=10
MIGRATIONS_PATH=file://db/migrations

# =========================================================
# Authentication
# =========================================================
# Generate a strong secret before production deployment.
JWT_SECRET=replace-with-long-random-production-secret
JWT_ISSUER=kivu-advisory
JWT_AUDIENCE=kivu-advisory-users
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=7

# =========================================================
# Password security
# =========================================================
PASSWORD_MIN_LENGTH=8
BCRYPT_COST=12

# =========================================================
# Cloudflare R2 private storage
# =========================================================
STORAGE_DRIVER=r2

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=kivu-advisory-prod-documents
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_REGION=auto

# Keep empty for private confidential documents.
# Do not expose private client files publicly.
R2_PUBLIC_BASE_URL=

# =========================================================
# Upload rules
# =========================================================
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,xls,xlsx,png,jpg,jpeg
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,image/png,image/jpeg

# =========================================================
# Email / SMTP
# =========================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=Kivu Advisory
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_USE_TLS=true

# =========================================================
# Notifications
# =========================================================
SEND_EMAIL_NOTIFICATIONS=true
NOTIFY_ADMIN_ON_NEW_REQUEST=true
NOTIFY_ADMIN_ON_DOCUMENT_UPLOAD=true
NOTIFY_CLIENT_ON_STATUS_CHANGE=true

# =========================================================
# Admin bootstrap
# =========================================================
# Used only when creating the first admin.
# Change password immediately after first login.
ADMIN_FULL_NAME=System Administrator
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace-with-temporary-secure-password
ADMIN_PHONE=

# =========================================================
# Frontend public fallback values
# These can later be managed from the admin content dashboard.
# =========================================================
NEXT_PUBLIC_APP_NAME=Kivu Advisory
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_COMPANY_PHONE=+250700000000
NEXT_PUBLIC_COMPANY_WHATSAPP=+250700000000
NEXT_PUBLIC_COMPANY_EMAIL=info@yourdomain.com
NEXT_PUBLIC_COMPANY_LOCATION=Rubavu, Rwanda

NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_X_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_TIKTOK_URL=

NEXT_PUBLIC_ENABLE_BLOG=true
NEXT_PUBLIC_ENABLE_CONSULTATION_BOOKING=true
NEXT_PUBLIC_ENABLE_CLIENT_REGISTRATION=true
NEXT_PUBLIC_ENABLE_TESTIMONIALS=true
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=20
NEXT_PUBLIC_ALLOWED_UPLOAD_EXTENSIONS=pdf,doc,docx,xls,xlsx,png,jpg,jpeg

# =========================================================
# Logging
# =========================================================
LOG_LEVEL=info
LOG_FORMAT=json
